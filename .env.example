# .env.example
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to version control

# Google OAuth2 Credentials
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CALENDAR_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=your-client-secret

# User-specific tokens
GOOGLE_CALENDAR_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_CALENDAR_REFRESH_TOKEN=your-refresh-token

# OAuth settings in FastAPI service
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8080/auth/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
GOOGLE_CALENDAR_OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_CALENDAR_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_CALENDAR_OAUTH_ALLOWED_TOKEN_HOSTS=oauth2.googleapis.com
GOOGLE_CALENDAR_OAUTH_PROMPT=consent
GOOGLE_CALENDAR_OAUTH_STATE_TTL_SECONDS=600
GOOGLE_CALENDAR_OAUTH_TOKEN_TIMEOUT_SECONDS=10

# Session settings in FastAPI service
GOOGLE_CALENDAR_SESSION_COOKIE_NAME=google_calendar_session_id
GOOGLE_CALENDAR_SESSION_IDENTIFIER=google_calendar_service_verifier
GOOGLE_CALENDAR_SESSION_SECRET=dev-only
GOOGLE_CALENDAR_SESSION_COOKIE_SECURE=false

# Other Settings
DEFAULT_CALENDAR_ID=primary
